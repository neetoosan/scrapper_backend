# Edge Contact Scraper — Backend Configuration
# Copy this file to .env and customize

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Scraper Settings
SCRAPER_MAX_CONCURRENT_JOBS=5
SCRAPER_DEFAULT_MAX_PAGES=12
SCRAPER_DOWNLOAD_DELAY=0.5
